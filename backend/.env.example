# Core application settings
HOST=127.0.0.1

# Gemini integration
# Required for merchant enrichment and audit summary generation.
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive upload via OAuth 2.0
# Use this option if you want uploaded checklists and generated FRDs
# to be pushed to a Google Drive folder.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Google Drive upload via service account
# Used only if OAuth credentials above are not provided.
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=./service-account-key.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Optional merchant-specific fallback/override text
MERCHANT_SERVICES=
